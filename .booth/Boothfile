# syntax=codingbooth/boothfile:1
# Configured by: booth config --no-tui --overwrite --variant notebook --port 31000 --expose 31173:5173 --select nodejs+npmrc+vscode-ext+pnpm-install/claude-code+auto-accept+credential+settings-cache

arg NODE_VERSION=22

# TEMP: system tools needed by utils/prepare-youtube.sh (qrencode for the QR,
# imagemagick's `convert` for JPG->PNG). Should move to a proper setup script.
# CodingBooth has no `apt--install.sh`, so use a raw RUN with apt-get.
run apt-get update && apt-get install -y --no-install-recommends qrencode imagemagick && rm -rf /var/lib/apt/lists/*

setup claude-code
setup nodejs ${NODE_VERSION}
install npm pnpm
setup nodejs-code-extension
run --mount=type=bind,target=/tmp/ctx if [ -f /tmp/ctx/package.json ]; then mkdir -p /opt/pnpm-cache && cp /tmp/ctx/package.json /opt/pnpm-cache/ && cp /tmp/ctx/pnpm-lock.yaml /opt/pnpm-cache/ 2>/dev/null || true && cp /tmp/ctx/pnpm-workspace.yaml /opt/pnpm-cache/ 2>/dev/null || true && cp /tmp/ctx/.npmrc /opt/pnpm-cache/ 2>/dev/null || true && cd /opt/pnpm-cache && pnpm install; fi
