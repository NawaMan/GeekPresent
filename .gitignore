# Dependencies
node_modules/

# SvelteKit / Vite build output
.svelte-kit/
/build/
/package/
/docs/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Local pnpm store (created by the booth)
.pnpm-store/

# CodingBooth runtime.
# Kept here, not in .booth/.gitignore, which the booth tooling rewrites.
# .booth/cache/ mirrors the container's ~/.claude — credentials and transcripts.
.booth/startups/
.booth/cache/
.booth/.tmp/

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
*~

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

dist/

dist.zip

# Narration pipeline — generated voice clips (large mp3s, regenerated in-booth;
# includes the _unused/ retirement folder). Plan/config/scripts stay tracked.
# See narration/PLAN.md §6, §14.
narration/**/voice_clips/

.booth/.tmp/

# Social cards — one PNG per slide, generated by `utils/capture-slides.sh --og`. They are
# BUILD OUTPUT, not source: derived from the slides themselves, ~200KB each, and stale the
# moment a slide changes. CI regenerates them before the build (see deploy-pages.yml), so
# they are served without ever being committed.
#
# The `image:` field they wire into each deck's pages.ts IS committed — that is the wiring,
# and it is the part a human should see in a diff.
/static/og/

# Local slide captures (`utils/capture-slides.sh` with no --og).
/captures/
